NODE_ENV=development
PORT=5000
DATABASE_URL="mysql://root:@localhost:3306/scmh"
JWT_SECRET="change-this-secret"
JWT_EXPIRES_IN="7d"
FRONTEND_URL="http://localhost:3000"

# Optional AI integration. Without OPENAI_API_KEY, the API returns a deterministic mock parse.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Optional SMTP. Without SMTP_HOST, email reminder is skipped safely.
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="SCMH <no-reply@scmh.local>"
